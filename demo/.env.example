# Copy to demo/.env and fill in. Used by demo/docker-compose.demo.yml.

# REQUIRED. Signing key for JWTs. Generate one with:
#   openssl rand -base64 32
JWT_SECRET=

# Public port the demo is served on (host side). Default 8089.
DEMO_PORT=8089

# Required under the prod profile. Set to the public URL the demo is served at
# (the origin browsers will use). With the tls profile below, use https + your
# domain, e.g. https://demo.stellargrooves.com
CORS_ALLOWED_ORIGINS=http://localhost:8089

# --- Auto-HTTPS (only used with the "tls" profile / Caddy) ---
# Public hostname Caddy serves and obtains a Let's Encrypt cert for. Point this
# domain's DNS A record at the host. Use "localhost" for a local trial (Caddy
# then uses a self-signed internal CA).
DEMO_DOMAIN=demo.stellargrooves.com
# Email Let's Encrypt uses for expiry/recovery notices (recommended).
ACME_EMAIL=you@example.com

# Contact string sent in the User-Agent when fetching cover art from public
# providers (MusicBrainz etiquette). Use a real address on a public instance.
COVER_ART_EXTERNAL_CONTACT=demo@stellargrooves.local
