# Stellar Grooves — environment variables
#
# Copy this file to `.env` and fill in values for your deployment.
# Variables marked REQUIRED have no safe default and must be set.
# Everything else falls back to the default shown in application.properties.

# =============================================================================
# REQUIRED
# =============================================================================

# JWT signing key. Base64-encoded, minimum 256 bits (32 raw bytes).
# Generate one with:  openssl rand -base64 48
# The app refuses to boot if this is missing or too short.
JWT_SECRET=

# Active Spring profile. Use `prod` for deployed instances, `dev` for local work.
SPRING_PROFILES_ACTIVE=prod

# CORS allowed origins (comma-separated, no trailing slash).
# REQUIRED when SPRING_PROFILES_ACTIVE=prod — app refuses to boot if empty in prod.
# Example: https://grooves.example.com,https://www.grooves.example.com
CORS_ALLOWED_ORIGINS=

# =============================================================================
# MongoDB
# =============================================================================

# Full connection URI. Default targets the docker-compose service.
MONGO_URI=mongodb://mongo:27017/stellar_grooves
# MONGO_CONNECT_TIMEOUT_MS=10000
# MONGO_SOCKET_TIMEOUT_MS=30000
# MONGO_SERVER_SELECTION_TIMEOUT_MS=15000

# =============================================================================
# Auth / JWT
# =============================================================================

# Access token lifetime in ms (default 15 min).
# JWT_EXPIRATION_MS=900000
# Refresh token lifetime in ms (default 7 days).
# REFRESH_TOKEN_EXPIRATION_MS=604800000
# LOGIN_MAX_FAILED_ATTEMPTS=5
# LOGIN_LOCKOUT_MINUTES=15
# SESSION_TIMEOUT=30m

# =============================================================================
# Server
# =============================================================================

# PORT=8080

# =============================================================================
# Rate limiting
# =============================================================================

# Public / shared-playlist endpoints (stricter).
# RATE_LIMIT_SHARED_MAX=5
# RATE_LIMIT_SHARED_WINDOW_MS=60000

# Authenticated heavy operations (export, bulk-delete, backup).
# USER_RATE_LIMIT_MAX=10
# USER_RATE_LIMIT_WINDOW_SECONDS=60

# Admin endpoints (user list, user deletion, catalog edits, catalog reload).
# ADMIN_RATE_LIMIT_MAX=20
# ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# Behind a load balancer? Set to true and list the proxy IPs you trust.
# RATE_LIMIT_TRUST_PROXY=true
# RATE_LIMIT_TRUSTED_PROXIES=127.0.0.1,::1

# =============================================================================
# Scanning
# =============================================================================

# SCAN_TIMEOUT_MINUTES=5
# SCAN_COOLDOWN_SECONDS=60
# SCAN_PER_FILE_TIMEOUT_SECONDS=30
# SCAN_FILE_READER_THREADS=2
# SCAN_SUPPORTED_EXTENSIONS=.mp3,.m4a,.flac
# SCAN_BATCH_SIZE=200
# SCAN_HARD_MAX_DEPTH=50

# Optional allowlist of absolute paths users may scan under.
# When empty, a blocklist of sensitive system paths applies instead.
# Strongly recommended on Windows (the blocklist is Unix-shaped).
# SCAN_ALLOWED_BASE_DIRS=/music,/home/user/music

# =============================================================================
# Smart playlists
# =============================================================================

# Hard ceiling on materialized result size.
# SMART_PLAYLIST_MATERIALIZE_MAX=5000

# =============================================================================
# Library / export / transcode
# =============================================================================

# SEARCH_MAX_QUERY_LENGTH=200
# EXPORT_MAX_SIZE=50000
# TRANSCODE_TIMEOUT_SECONDS=300
# TRANSCODE_MAX_FILE_SIZE=524288000
# QUEUE_MAX_TRACKS=5000

# =============================================================================
# Trash / retention
# =============================================================================

# Days to retain soft-deleted files. Set 0 to disable purging.
# TRASH_RETENTION_DAYS=30
# TRASH_PURGE_CRON=0 0 3 * * *

# =============================================================================
# Cover art
# =============================================================================

# COVER_ART_MAX_BYTES_PER_IMAGE=10485760
# COVER_ART_QUOTA_BYTES=524288000

# Global cover-art disk ceiling across all users. Default 10 GB.
# Set to 0 to disable the check.
# COVER_ART_GLOBAL_QUOTA_BYTES=10737418240

# =============================================================================
# Mail (password reset + email verification)
# =============================================================================

# MAIL_ENABLED=false
# MAIL_HOST=localhost
# MAIL_PORT=587
# MAIL_USERNAME=
# MAIL_PASSWORD=
# MAIL_SMTP_AUTH=true
# MAIL_SMTP_STARTTLS=true
# MAIL_FROM=noreply@stellargrooves.local

# Require users to verify their email before login. Requires MAIL_ENABLED=true.
# EMAIL_VERIFICATION_REQUIRED=false

# Base URL used in outbound links (verification, password reset).
# BASE_URL=http://localhost:8080
